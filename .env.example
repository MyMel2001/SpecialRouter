# Server Configuration
PORT=5055

# Router Configuration
ROUTER_VIRTUAL_MODEL_NAME=specialrouter
# Optional: If set, users must provide this as a Bearer token
ROUTER_API_KEY=x

# Chooser Model Configuration
# This model decides which specialist to use
CHOOSER_MODEL_ENDPOINT=http://100.118.11.83:11434/v1/chat/completions
CHOOSER_MODEL_NAME=ministral-3:3b
CHOOSER_MODEL_API_KEY=sk-proj-xxxx

# Fallback ("Other") Model Configuration
# Used if the chooser fails or returns an invalid choice
FALLBACK_MODEL_ENDPOINT=http://100.118.11.83:11434/v1/chat/completions
FALLBACK_MODEL_NAME=sparksammy/samantha-combo-3.5:latest
FALLBACK_MODEL_API_KEY=sk-proj-xxxx

# Specialist Models
# You can add as many as you want by incrementing the number
# Ensure the variable names match the pattern: SPECIALIST_{N}_...

SPECIALIST_1_TOPIC="Coding, Software Engineering, and Technical Architecture with Samantha"
SPECIALIST_1_MODEL_ENDPOINT=http://100.118.11.83:11434/v1/chat/completions
SPECIALIST_1_MODEL_NAME=sparksammy/samantha-combo-3.2:latest
SPECIALIST_1_MODEL_API_KEY=sk-proj-xxxx

