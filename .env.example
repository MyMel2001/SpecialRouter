# Server Configuration
PORT=3000

# Router Configuration
ROUTER_VIRTUAL_MODEL_NAME=specialist-router
# Optional: If set, users must provide this as a Bearer token
ROUTER_API_KEY=your-secret-api-key

# Chooser Model Configuration
# This model decides which specialist to use
CHOOSER_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
CHOOSER_MODEL_NAME=gpt-4o
CHOOSER_MODEL_API_KEY=sk-proj-xxxx

# Fallback ("Other") Model Configuration
# Used if the chooser fails or returns an invalid choice
FALLBACK_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
FALLBACK_MODEL_NAME=gpt-4o
FALLBACK_MODEL_API_KEY=sk-proj-xxxx

# Specialist Models
# You can add as many as you want by incrementing the number
# Ensure the variable names match the pattern: SPECIALIST_{N}_...

SPECIALIST_1_TOPIC="Coding, Software Engineering, and Technical Architecture"
SPECIALIST_1_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
SPECIALIST_1_MODEL_NAME=gpt-4o
SPECIALIST_1_MODEL_API_KEY=sk-proj-xxxx

SPECIALIST_2_TOPIC="Creative Writing, Poetry, and Storytelling"
SPECIALIST_2_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
SPECIALIST_2_MODEL_NAME=gpt-4-turbo
SPECIALIST_2_MODEL_API_KEY=sk-proj-xxxx

SPECIALIST_3_TOPIC="Data Analysis, Mathematics, and Statistics"
SPECIALIST_3_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
SPECIALIST_3_MODEL_NAME=o1-preview
SPECIALIST_3_MODEL_API_KEY=sk-proj-xxxx
